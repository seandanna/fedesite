modules = ["nodejs-20"]
run = "fuser -k 5000/tcp 2>/dev/null; npx --yes serve . -p 5000"

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp 2>/dev/null; npx --yes serve . -p 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[nix]
packages = ["psmisc"]
